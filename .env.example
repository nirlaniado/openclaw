NEXT_PUBLIC_APP_NAME=Nutrition Tracker
# Public base URL of the deployment. Locally use http://localhost:3000.
# On Vercel set this to your deployment domain (e.g. https://your-app.vercel.app)
# so auth email/redirect links point to the right place.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Supabase API URL — the project ref host, NOT the dashboard URL.
# Correct:   https://<project-ref>.supabase.co
# Incorrect: https://supabase.com/dashboard/project/<project-ref>
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
USDA_API_KEY=
# Ollama host. Locally this is the default. For a remote host (e.g. EC2) use the
# public HTTPS endpoint of the reverse proxy in front of Ollama, e.g.
# https://ollama.your-domain.com  (do NOT expose raw port 11434 to the internet).
OLLAMA_BASE_URL=http://localhost:11434
# Model tag as shown by `ollama list` on the host, e.g. llama3.2:1b
OLLAMA_MODEL=
# Optional bearer token your reverse proxy checks before forwarding to Ollama.
# Leave blank for local/unauthenticated dev.
OLLAMA_API_KEY=
# Set to "ollama" to enable LLM meal parsing; "stub" keeps the no-op adapter.
LLM_PROVIDER=stub
LOG_LEVEL=info
