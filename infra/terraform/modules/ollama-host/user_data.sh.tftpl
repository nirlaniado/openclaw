#!/usr/bin/env bash
set -euxo pipefail

export DEBIAN_FRONTEND=noninteractive

# --- Ollama -----------------------------------------------------------------
# Installs and starts the ollama systemd service (binds to 127.0.0.1:11434 by
# default, which is what we want: only Caddy talks to it locally).
curl -fsSL https://ollama.com/install.sh | sh
systemctl enable --now ollama

# Wait for the API to come up, then pull the model.
until curl -sf http://127.0.0.1:11434/api/tags >/dev/null; do
  sleep 2
done
ollama pull "${ollama_model}"

# --- Caddy reverse proxy ----------------------------------------------------
apt-get update
apt-get install -y debian-keyring debian-archive-keyring apt-transport-https curl gnupg
curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' \
  | gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' \
  | tee /etc/apt/sources.list.d/caddy-stable.list
apt-get update
apt-get install -y caddy

cat > /etc/caddy/Caddyfile <<'CADDYFILE'
${caddyfile}
CADDYFILE

systemctl enable caddy
systemctl restart caddy
